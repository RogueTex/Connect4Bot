# Anvil Uplink Configuration
# Get this from your Anvil app settings > Uplink
ANVIL_UPLINK_KEY=your_anvil_uplink_key_here

# Model Paths (relative to aws-deploy/)
# Path to the primary CNN model checkpoint
CNN_MODEL_PATH=models/cnn2_model.keras

# Path to the Transformer model checkpoint (optional)
TRANSFORMER_MODEL_PATH=models/transformer_model.keras

# Server Configuration
# Port for the local development server
SERVER_PORT=8080

# Logging
# Set to DEBUG for verbose output, INFO for normal, WARNING for minimal
LOG_LEVEL=INFO

# Data Logging (optional)
# Directory to store gameplay logs for fine-tuning
GAMEPLAY_LOG_DIR=./logs
